{
  "name": "secure-host-mcp",
  "version": "0.1.0",
  "description": "Cross-platform remote terminal MCP server with OAuth, jobs, tunnels, and auditing",
  "type": "module",
  "bin": {
    "secure-host-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts start",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js start",
    "package:standalone": "node scripts/package-standalone.mjs"
  },
  "keywords": [
    "mcp",
    "terminal",
    "chatgpt",
    "oauth",
    "cloudflared",
    "frpc"
  ],
  "license": "MIT",
  "overrides": {
    "@hono/node-server": "^2.0.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "commander": "^14.0.0",
    "express": "^5.1.0",
    "jose": "^6.1.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.34.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  }
}
